{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoresearch-paper.local/schemas/figure-requirements.schema.json",
  "title": "Frozen plan figure requirements",
  "description": "Controller-owned pre-writing figure identity set approved at CP-01.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "tier", "expected_figure_ids"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "plan_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "tier": {
      "type": "string",
      "enum": ["arxiv", "conference", "journal-q1"]
    },
    "expected_figure_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
      }
    }
  }
}
